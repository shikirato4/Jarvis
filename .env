JARVIS_APP_NAME=Jarvis
JARVIS_ENVIRONMENT=local
JARVIS_LOG_LEVEL=INFO
JARVIS_DATA_DIR=runtime
JARVIS_WORKSPACE_ROOT=.
JARVIS_JSON_LOGS=true
JARVIS_COMMAND_ALLOWLIST=[]
JARVIS_MODEL_PROVIDER_DEFAULT=gpt_oss
JARVIS_MODEL_PROVIDER_FALLBACK_ORDER=[]
JARVIS_GENERAL_CHAT_MODEL_PROVIDER=gpt_oss
JARVIS_GENERAL_CHAT_MODEL_FALLBACK_ORDER=[]
JARVIS_GPT_OSS_ENABLED=true
JARVIS_GPT_OSS_BASE_URL=http://127.0.0.1:11434/v1
JARVIS_GPT_OSS_CHAT_ENDPOINT=/chat/completions
JARVIS_GPT_OSS_MODELS_ENDPOINT=/models
JARVIS_GPT_OSS_GENERAL_MODEL=gpt-oss:20b
JARVIS_GPT_OSS_REASONING_MODEL=gpt-oss:20b
JARVIS_GPT_OSS_CODING_MODEL=gpt-oss:20b
JARVIS_GPT_OSS_SUMMARIZER_MODEL=gpt-oss:20b
JARVIS_GPT_OSS_WRITING_MODEL=gpt-oss:20b
JARVIS_GPT_OSS_PLANNER_MODEL=gpt-oss:20b
JARVIS_OLLAMA_ENABLED=false
JARVIS_EMBEDDINGS_ENABLED=false
JARVIS_GPT_OSS_TIMEOUT_SECONDS=600
JARVIS_GPT_OSS_HEALTHCHECK_TIMEOUT_SECONDS=20
JARVIS_VOICE_PROFILE_DEFAULT=jarvis_serious
JARVIS_VOICE_FORMALITY_LEVEL=4
JARVIS_VOICE_TTS_RATE=168
JARVIS_VOICE_STYLE_ENABLED=true
JARVIS_VOICE_CLEANUP_ENABLED=true
