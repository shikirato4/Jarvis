JARVIS_APP_NAME=Jarvis
JARVIS_ENVIRONMENT=local
JARVIS_LOG_LEVEL=INFO
JARVIS_DATA_DIR=runtime
JARVIS_WORKSPACE_ROOT=.
JARVIS_JSON_LOGS=true
JARVIS_COMMAND_ALLOWLIST=
JARVIS_IMAGE_ENABLED=true
JARVIS_IMAGE_BACKEND=diffusers
JARVIS_IMAGE_MODEL_PATH=models/image/checkpoints/juggernautXL_v8Rundiffusion.safetensors
JARVIS_IMAGE_OUTPUT_DIR=outputs/images
JARVIS_IMAGE_TIMEOUT_SECONDS=1800
